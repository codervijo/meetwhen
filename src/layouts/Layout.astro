---
// Shared page chrome: <html> shell, base meta, and global stylesheet.
// Page-specific <head> tags are injected via the named "head" slot.
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>
